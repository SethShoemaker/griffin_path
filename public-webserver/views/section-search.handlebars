<div class="p-6 space-y-6">

    <form method="GET" class="card bg-base-200 p-6 space-y-4">

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {{#each filters}}
            <div>
                <label class="label">
                    <span class="label-text font-semibold">{{this.label}}</span>
                </label>

                {{#if (eq this.type "text_search")}}
                <input type="text" name="{{this.inputName}}" value="{{this.value}}"
                    class="input input-bordered w-full" placeholder="{{this.placeholder}}" />
                {{/if}}

                {{#if (eq this.type "multi_select_or")}}
                <div class="dropdown w-full">
                    <div tabindex="0" role="button"
                        class="input input-bordered w-full flex items-center cursor-pointer">
                        {{this.placeholder}}
                    </div>

                    <div tabindex="0"
                        class="dropdown-content z-[1] mt-1 w-full p-2 shadow bg-base-100 rounded-box border">

                        <select name="{{this.inputName}}" multiple class="select select-ghost w-full">

                            {{#each this.inputOptions}}
                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>
                                {{this.label}}
                            </option>
                            {{/each}}

                        </select>

                    </div>
                </div>
                {{/if}}
            </div>
            {{/each}}
        </div>

        <div class="flex gap-2">
            <button type="submit" class="btn btn-primary">Apply Filters</button>
            <a href="/" class="btn btn-ghost">Reset</a>
        </div>

    </form>

    <div class="flex justify-center mt-6">
        <div class="join">

            <button class="join-item btn {{#if (lte page 1)}}btn-disabled{{/if}}"
                onclick="gotoPage({{subtract page 1}})">
                ‹
            </button>

            {{#each (array 0 1 2 3 4)}}
            {{#with (add (max 1 (min (subtract ../page 2) (subtract ../totalPages 4))) this)}}
            {{#if (and (gte this 1) (lte this ../../totalPages))}}
            <button class="join-item btn {{#if (eq this ../../page)}}btn-active{{/if}}" onclick="gotoPage({{this}})">
                {{this}}
            </button>
            {{/if}}
            {{/with}}
            {{/each}}

            <button class="join-item btn {{#if (gte page totalPages)}}btn-disabled{{/if}}"
                onclick="gotoPage({{add page 1}})">
                ›
            </button>

        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="table table-zebra w-full">

            <thead>
                <tr>
                    {{#each columns}}
                    <th>{{this.name}}</th>
                    {{/each}}
                </tr>
            </thead>

            <tbody>
                {{#each records}}
                <tr>
                    {{#each ../columns}}
                    <td>{{lookup ../this this.field}}</td>
                    {{/each}}
                </tr>
                {{else}}
                <tr>
                    <td colspan="{{config.columns.length}}" class="text-center p-4">
                        No results found
                    </td>
                </tr>
                {{/each}}
            </tbody>

        </table>
    </div>

    <div class="flex justify-center mt-6">
        <div class="join">

            <button class="join-item btn {{#if (lte page 1)}}btn-disabled{{/if}}"
                onclick="gotoPage({{subtract page 1}})">
                ‹
            </button>

            {{#each (array 0 1 2 3 4)}}
            {{#with (add (max 1 (min (subtract ../page 2) (subtract ../totalPages 4))) this)}}
            {{#if (and (gte this 1) (lte this ../../totalPages))}}
            <button class="join-item btn {{#if (eq this ../../page)}}btn-active{{/if}}" onclick="gotoPage({{this}})">
                {{this}}
            </button>
            {{/if}}
            {{/with}}
            {{/each}}

            <button class="join-item btn {{#if (gte page totalPages)}}btn-disabled{{/if}}"
                onclick="gotoPage({{add page 1}})">
                ›
            </button>

        </div>
    </div>

    <script>
        function gotoPage(page) {
            const params = new URLSearchParams(window.location.search);
            params.set("page", page);
            params.set("per_page", {{ perPage }});
            window.location.search = params.toString();
        }
    </script>

</div>