<div class="p-6 space-y-6">

    <h1 class="text-5xl md:text-6xl font-bold tracking-tight"> {{ config.headingText }}</h1>

    <form method="GET" class="card bg-base-200 p-6 space-y-4" id="searchForm">

        <input type="hidden" name="lastInputInteractedWith" id="lastInputInteractedWith">

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {{#each filters}}
            <div>
                <label class="label">
                    <span class="label-text font-semibold">{{this.label}}</span>
                </label>

                {{#if (eq this.type "text_search")}}
                <input type="text" name="{{this.inputName}}" value="{{this.value}}" class="input input-bordered w-full"
                    placeholder="{{this.placeholder}}" oninput="onInputChange('{{this.inputName}}' + '__' + this.selectionStart, 500)" id="text-search-input-{{this.inputName}}" />
                {{#if this.autoFocus }} 
                <script>
                    window.addEventListener("DOMContentLoaded", function() {
                        document.getElementById("text-search-input-{{this.inputName}}").focus();
                        document.getElementById("text-search-input-{{this.inputName}}").setSelectionRange({{this.cursorPosition}}, {{this.cursorPosition}});
                        const url = new URL(window.location.href);
                        url.searchParams.delete("lastInputInteractedWith");
                        window.history.replaceState({}, "", url);
                    });
                </script>
                {{/if}}
                {{/if}}

                {{#if (eq this.type "multi_select_or")}}
                <div class="dropdown w-full">
                    <div tabindex="0" role="button"
                        class="input input-bordered w-full flex items-center cursor-pointer" id="multi-select-or-button-{{this.inputName}}">
                        {{this.placeholder}}
                    </div>

                    {{#if this.autoFocus }}
                    <script>
                        window.addEventListener("DOMContentLoaded", function() {
                            document.getElementById("multi-select-or-button-{{this.inputName}}").focus()
                            const url = new URL(window.location.href);
                            url.searchParams.delete("lastInputInteractedWith");
                            window.history.replaceState({}, "", url);
                        });
                    </script>
                    {{/if}}

                    <div tabindex="0"
                        class="dropdown-content z-[1] mt-1 w-full p-2 shadow bg-base-100 rounded-box border">

                        <select name="{{this.inputName}}" id="{{this.inputName}}" multiple
                            class="select select-ghost w-full" onchange="onInputChange('{{this.inputName}}', 0)" >

                            {{#each this.inputOptions}}
                            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>
                                {{this.label}}
                            </option>
                            {{/each}}

                        </select>

                    </div>
                </div>
                {{/if}}
            </div>
            {{/each}}
        </div>

        <div class="flex gap-2">
            <button type="submit" class="btn btn-primary">Apply Filters</button>
            <a href="/" class="btn btn-ghost">Reset</a>
        </div>

    </form>

    <div class="flex justify-center mt-6">
        <div class="join">

            <button class="join-item btn {{#if (lte page 1)}}btn-disabled{{/if}}"
                onclick="gotoPage({{subtract page 1}})">
                ‹
            </button>

            {{#each (array 0 1 2 3 4)}}
            {{#with (add (max 1 (min (subtract ../page 2) (subtract ../totalPages 4))) this)}}
            {{#if (and (gte this 1) (lte this ../../totalPages))}}
            <button class="join-item btn {{#if (eq this ../../page)}}btn-active{{/if}}" onclick="gotoPage({{this}})">
                {{this}}
            </button>
            {{/if}}
            {{/with}}
            {{/each}}

            <button class="join-item btn {{#if (gte page totalPages)}}btn-disabled{{/if}}"
                onclick="gotoPage({{add page 1}})">
                ›
            </button>

        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="table table-zebra w-full">

            <thead>
                <tr>
                    {{#each columns}}
                    <th>{{this.name}}</th>
                    {{/each}}
                </tr>
            </thead>

            <tbody>
                {{#each records}}
                <tr>
                    {{#each ../columns}}
                    <td style="white-space: pre-line">{{lookup ../this this.field}}</td>
                    {{/each}}
                </tr>
                {{else}}
                <tr>
                    <td colspan="{{config.columns.length}}" class="text-center p-4">
                        No results found
                    </td>
                </tr>
                {{/each}}
            </tbody>

        </table>
    </div>

    <div class="flex justify-center mt-6">
        <div class="join">

            <button class="join-item btn {{#if (lte page 1)}}btn-disabled{{/if}}"
                onclick="gotoPage({{subtract page 1}})">
                ‹
            </button>

            {{#each (array 0 1 2 3 4)}}
            {{#with (add (max 1 (min (subtract ../page 2) (subtract ../totalPages 4))) this)}}
            {{#if (and (gte this 1) (lte this ../../totalPages))}}
            <button class="join-item btn {{#if (eq this ../../page)}}btn-active{{/if}}" onclick="gotoPage({{this}})">
                {{this}}
            </button>
            {{/if}}
            {{/with}}
            {{/each}}

            <button class="join-item btn {{#if (gte page totalPages)}}btn-disabled{{/if}}"
                onclick="gotoPage({{add page 1}})">
                ›
            </button>

        </div>
    </div>

    <div class="flex justify-center mt-6">
        <button class="btn btn-secondary" onclick="changeTheme()">Change Theme</button>
    </div>

    <script>
        function gotoPage(page) {
            const params = new URLSearchParams(window.location.search);
            params.delete("lastInputInteractedWith")
            params.set("page", page);
            params.set("per_page", {{ perPage }});
            window.location.search = params.toString();
        }

        function setCookie(name, value) {
            const expires = new Date();
            expires.setFullYear(expires.getFullYear() + 20);

            document.cookie =
                encodeURIComponent(name) +
                "=" +
                encodeURIComponent(value) +
                "; expires=" + expires.toUTCString() +
                "; path=/";
        }

        function getCookie(name) {
            const nameEq = encodeURIComponent(name) + "=";

            const cookies = document.cookie.split("; ");
            for (const cookie of cookies) {
                if (cookie.startsWith(nameEq)) {
                    return decodeURIComponent(cookie.substring(nameEq.length));
                }
            }

            return null;
        }

        function changeTheme() {
            setCookie("colorScheme", getCookie("colorScheme") == "light" ? "dark" : "light");
            location.reload();
        }

        function onInputChange(inputName, delay = 500) {
            clearTimeout(window._debounceTimer);
            window._debounceTimer = setTimeout(() => submitSearch(inputName), delay);
        }

        function submitSearch(lastInputInteractedWith = "") {
            if (lastInputInteractedWith.length > 0) {
                document.querySelector('#lastInputInteractedWith').value = lastInputInteractedWith;
            }
            document.querySelector('#searchForm').submit();
        }

    </script>

</div>